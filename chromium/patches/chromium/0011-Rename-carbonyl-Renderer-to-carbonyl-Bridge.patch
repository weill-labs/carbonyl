From 9b3bbed8ca4cf235a6c27f166fce283b8fecc552 Mon Sep 17 00:00:00 2001
From: Fathy Boundjadj <hey@fathy.fr>
Date: Sun, 12 Feb 2023 01:29:05 +0100
Subject: [PATCH 11/17] Rename carbonyl::Renderer to carbonyl::Bridge

---
 headless/app/headless_shell.cc                          | 1 +
 headless/lib/browser/headless_platform_delegate_aura.cc | 2 +-
 headless/lib/browser/headless_screen.cc                 | 2 +-
 3 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/headless/app/headless_shell.cc b/headless/app/headless_shell.cc
index 5ef5d57acc4c7..898a1cba60c4a 100644
--- a/headless/app/headless_shell.cc
+++ b/headless/app/headless_shell.cc
@@ -108,6 +108,7 @@ void HeadlessShell::OnBrowserStart(HeadlessBrowser* browser) {
   HeadlessBrowserContext::Builder context_builder =
       browser_->CreateBrowserContextBuilder();
 
+  carbonyl::Renderer::GetCurrent()->StartRenderer();
   context_builder.SetWindowSize(carbonyl::Renderer::GetCurrent()->GetSize());
 
   // Retrieve the locale set by InitApplicationLocale() in
diff --git a/headless/lib/browser/headless_platform_delegate_aura.cc b/headless/lib/browser/headless_platform_delegate_aura.cc
index 89192cac345fd..39993a2d7754d 100644
--- a/headless/lib/browser/headless_platform_delegate_aura.cc
+++ b/headless/lib/browser/headless_platform_delegate_aura.cc
@@ -66,7 +66,7 @@ void HeadlessPlatformDelegate::SetWebContentsBounds(
 
   // Update RootWindow.
   web_contents->window_tree_host()->SetBoundsInPixels(
-      ScaleToEnclosedRect(bounds, carbonyl::Renderer::GetDPI()));
+      ScaleToEnclosedRect(bounds, carbonyl::Bridge::GetDPI()));
 }
 
 ui::Compositor* HeadlessPlatformDelegate::GetCompositor(
diff --git a/headless/lib/browser/headless_screen.cc b/headless/lib/browser/headless_screen.cc
index ff51574913b8e..29d507868d1d4 100644
--- a/headless/lib/browser/headless_screen.cc
+++ b/headless/lib/browser/headless_screen.cc
@@ -92,7 +92,7 @@ void HeadlessScreen::CreateDisplayList(const gfx::Size& window_size,
   if (screen_info_spec.empty()) {
     screen_info.push_back(HeadlessScreenInfo(
         {.bounds = gfx::Rect(window_size),
-         .device_pixel_ratio = carbonyl::Renderer::GetDPI()}));
+         .device_pixel_ratio = carbonyl::Bridge::GetDPI()}));
   } else {
     screen_info = HeadlessScreenInfo::FromString(screen_info_spec).value();
     CHECK(!screen_info.empty());
