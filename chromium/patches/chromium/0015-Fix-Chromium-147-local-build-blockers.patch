-# Regex for a line that specifies inter-file dependencies in a `.d` file.
-#
-# The syntax for such files follows the Makefile syntax and a regex is not
-# necessarily the best way to parse the lines. But this is what we started
-# with and it worked reasonably well so far. The main known issue is that
-# spaces in filenames are not supported.
-#
-# Other notes:
-# * We rely on greediness of `*` and `+`
-# * "#" is rejected as the first character to reject lines like
-#   `# env-dep:OUT_DIR=foo/bar`.
-FILE_RE = re.compile("^([^# ][^ ]*):( .+)?$")
+
+def _split_depfile_tokens(text):
+    """Splits a Make-style depfile path list, honoring backslash escapes."""
+
+    tokens = []
+    current = []
+    escaped = False
+    for ch in text:
+        if escaped:
+            current.append(ch)
+            escaped = False
+        elif ch == "\\":
+            escaped = True
+        elif ch.isspace():
+            if current:
+                tokens.append("".join(current))
+                current = []
+        else:
+            current.append(ch)
+
+    if escaped:
+        current.append("\\")
+    if current:
+        tokens.append("".join(current))
+    return tokens
+
+
+def _parse_depfile_line(depline):
+    """Parses a Make-style depfile line into `(target, dependencies)`."""
+
+    stripped = depline.rstrip("\n")
+    if not stripped or stripped.startswith("#"):
+        return None
+
+    separator = None
+    escaped = False
+    for i, ch in enumerate(stripped):
+        if escaped:
+            escaped = False
+            continue
+        if ch == "\\":
+            escaped = True
+            continue
+
+        # Treat `:` as the target/dependency separator only when it is followed by
+        # whitespace or the end of line. This avoids misparsing paths such as
+        # `C:/foo/bar` when targeting Windows.
+        if ch == ":" and (i + 1 == len(stripped) or stripped[i + 1].isspace()):
+            separator = i
+            break
+
+    if separator is None:
+        return None
+
+    lhs_tokens = _split_depfile_tokens(stripped[:separator])
+    if len(lhs_tokens) != 1:
+        return None
+
+    return lhs_tokens[0], _split_depfile_tokens(stripped[separator + 1 :])
+
+
+def _escape_depfile_path(path):
+    return path.replace("\\", "\\\\").replace(" ", "\\ ")
 
 
