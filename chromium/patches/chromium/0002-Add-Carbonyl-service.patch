+void LayerTreeHost::StartTerminalRender() {
+  DCHECK(IsMainThread());
+
+  auto it = terminal_render_callbacks_.begin();
+
+  while (it != terminal_render_callbacks_.end()) {
+    auto& callback = *it->get();
+
+    if (callback) {
+      callback();
+
+      it++;
+    } else {
+      it = terminal_render_callbacks_.erase(it);
+    }
+  }
+}
 
